<Window x:Class="StoryLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StoryLauncher"
        mc:Ignorable="d"
        Title="StoryLauncher"
        Icon="/StoryLauncher;component/Assets/Icons/LauncherIcon.ico"
        Width="1280"
        Height="720"
        MinWidth="1100"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource LauncherBackgroundBrush}">

    <Window.Resources>

        <!-- Стиль кнопки музыки -->
        <Style x:Key="TopIconButtonStyle"
               TargetType="Button">

            <Setter Property="Width"
                    Value="40"/>

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Foreground"
                    Value="#B9BECA"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="IconBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="IconBorder"
                                        Property="Background"
                                        Value="#20242F"/>

                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="IconBorder"
                                        Property="Background"
                                        Value="#292E3B"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль ползунка громкости -->
        <Style x:Key="VolumeSliderStyle"
               TargetType="Slider">

            <Setter Property="Height"
                    Value="24"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">

                        <Grid VerticalAlignment="Center">

                            <Grid Height="20"
                                  VerticalAlignment="Center">

                                <!-- Серый фон линии -->
                                <Border Height="4"
                                        VerticalAlignment="Center"
                                        Background="#323744"
                                        CornerRadius="2"/>

                                <Track x:Name="PART_Track">

                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                      IsHitTestVisible="False">

                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">

                                                    <!-- Заполненная часть ползунка -->
                                                    <Border Height="4"
                                                            Background="{DynamicResource PrimaryBrush}"
                                                            CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb Width="15"
                                               Height="15">

                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">

                                                    <Grid>

                                                        <Ellipse Width="15"
                                                                 Height="15"
                                                                 Fill="#FFFFFF"/>

                                                        <Ellipse Width="7"
                                                                 Height="7"
                                                                 Fill="{DynamicResource PrimaryBrush}"/>
                                                    </Grid>

                                                    <ControlTemplate.Triggers>

                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">

                                                            <Setter Property="Cursor"
                                                                    Value="Hand"/>
                                                        </Trigger>

                                                        <Trigger Property="IsDragging"
                                                                 Value="True">

                                                            <Setter Property="Cursor"
                                                                    Value="Hand"/>
                                                        </Trigger>

                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                      IsHitTestVisible="False">

                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>

                                </Track>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#5C0D0F14">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0"
                Background="#B811141B"
                BorderBrush="#252A35"
                BorderThickness="0,0,1,0">

            <Grid Margin="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Зацикленная видео-аватарка -->
                <StackPanel HorizontalAlignment="Center">

                    <Grid Width="150"
                          Height="150"
                          HorizontalAlignment="Center">

                        <!-- Запасная картинка, если MP4 отсутствует или не поддерживается. -->
                        <Ellipse x:Name="SidebarAvatarFallback"
                                 Width="144"
                                 Height="144">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/StoryLauncher;component/Assets/Images/SidebarAvatar.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <MediaElement x:Name="SidebarAvatarVideo"
                                      Width="144"
                                      Height="144"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      Stretch="UniformToFill"
                                      IsMuted="True"
                                      ScrubbingEnabled="True"
                                      SpeedRatio="0.8"
                                      Opacity="0"
                                      MediaOpened="SidebarAvatarVideo_MediaOpened"
                                      MediaEnded="SidebarAvatarVideo_MediaEnded"
                                      MediaFailed="SidebarAvatarVideo_MediaFailed">
                            <MediaElement.Clip>
                                <EllipseGeometry Center="72,72"
                                                 RadiusX="72"
                                                 RadiusY="72"/>
                            </MediaElement.Clip>
                        </MediaElement>

                        <!-- Рамка остаётся поверх видео и меняет цвет вместе с темой. -->
                        <Ellipse Width="150"
                                 Height="150"
                                 Stroke="{DynamicResource PrimaryBrush}"
                                 StrokeThickness="3"
                                 Fill="Transparent"
                                 IsHitTestVisible="False"/>
                    </Grid>

                    <TextBlock Text="STORY LAUNCHER"
                               Margin="0,8,0,0"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Новости -->
                <Button x:Name="HomeButton"
                        Grid.Row="2"
                        Style="{StaticResource SelectedNavigationButtonStyle}"
                        Click="HomeButton_Click">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="&#xE80F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="Новости"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Модпак -->
                <Button x:Name="ModpackButton"
                        Grid.Row="3"
                        Style="{StaticResource NavigationButtonStyle}"
                        Click="ModpackButton_Click">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="&#xE7B8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="Модпак"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Персонализация лаунчера -->
                <Button x:Name="CustomLauncherButton"
                        Grid.Row="4"
                        Style="{StaticResource NavigationButtonStyle}"
                        Click="CustomLauncherButton_Click">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="&#xE790;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="Custom Launcher"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Настройки -->
                <Button x:Name="SettingsButton"
                        Grid.Row="5"
                        Style="{StaticResource NavigationButtonStyle}"
                        Click="SettingsButton_Click">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="Настройки"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Discord-сообщество -->
                <Button Grid.Row="6"
                        Height="46"
                        Margin="0,0,0,112"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource NavigationButtonStyle}"
                        ToolTip="Открыть Discord StoryLauncher"
                        Click="DiscordButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8BD;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="19"
                                   Margin="0,0,14,0"
                                   Foreground="#8A9CFF"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Discord"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Музыка и громкость внизу бокового меню -->
                <Border Grid.Row="6"
                        Margin="0,0,0,16"
                        Padding="10"
                        VerticalAlignment="Bottom"
                        Background="#A8171B24"
                        BorderBrush="#4D3B4150"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="MusicButton"
                                    Width="32"
                                    Height="32"
                                    Style="{StaticResource TopIconButtonStyle}"
                                    ToolTip="Включить или выключить музыку"
                                    Click="MusicButton_Click">
                                <TextBlock x:Name="MusicIcon"
                                           Text="&#xE767;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="17"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <TextBlock Grid.Column="1"
                                       Text="Музыка"
                                       Margin="7,0,0,0"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="VolumeText"
                                       Grid.Column="2"
                                       Text="35%"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Slider x:Name="VolumeSlider"
                                Margin="3,6,3,0"
                                Minimum="0"
                                Maximum="100"
                                Value="35"
                                SmallChange="1"
                                LargeChange="5"
                                IsMoveToPointEnabled="True"
                                Style="{StaticResource VolumeSliderStyle}"
                                ValueChanged="VolumeSlider_ValueChanged"
                                ToolTip="Громкость музыки"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="LauncherVersionText"
                           Grid.Row="7"
                           Text="Версия лаунчера"
                           Margin="2,0,0,2"
                           Foreground="#697184"
                           FontSize="12"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0"
                    Background="#B80F1218"
                    BorderBrush="#252A35"
                    BorderThickness="0,0,0,1">

                <Grid Margin="28,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Название страницы -->
                    <TextBlock x:Name="PageTitle"
                               Text="Новости"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <!-- Правая часть верхней панели -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Кнопка профиля -->
                        <Button x:Name="ProfileButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand"
                                Click="ProfileButton_Click">

                            <Border Padding="18,10"
                                    Background="#B8171B24"
                                    BorderBrush="#272C38"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="34"
                                          Height="34">
                                        <Ellipse Width="30"
                                                 Height="30"
                                                 Fill="#55242936"/>

                                        <TextBlock x:Name="ProfileFallbackIcon"
                                                   Text="&#xE77B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <Image x:Name="ProfileAvatarImage"
                                               Width="30"
                                               Height="30"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="Collapsed">
                                            <Image.Clip>
                                                <EllipseGeometry Center="15,15"
                                                                 RadiusX="15"
                                                                 RadiusY="15"/>
                                            </Image.Clip>
                                        </Image>

                                        <!-- Рамка всегда находится поверх изображения. -->
                                        <Ellipse Width="33"
                                                 Height="33"
                                                 Stroke="{DynamicResource PrimaryBrush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"
                                                 IsHitTestVisible="False"/>
                                    </Grid>
                                    <TextBlock Text="Профиль"
                                               Margin="10,0,0,0"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfileNameText" Visibility="Collapsed"/>
                                    <TextBlock x:Name="ProfileStatusText" Visibility="Collapsed"/>
                                    <TextBlock x:Name="ProfileAvatarText" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Здесь открываются страницы -->
            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>
    </Grid>
</Window>
