<Page x:Class="StoryLauncher.Views.CustomLauncherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Opacity="0"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <Style x:Key="ThemeChoiceButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="224"/>
            <Setter Property="Height" Value="118"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#11151D"/>
            <Setter Property="BorderBrush" Value="#2B303D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChoiceBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChoiceBorder"
                                        Property="Background"
                                        Value="#1D222D"/>
                                <Setter TargetName="ChoiceBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MusicChoiceButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="270"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#9911151D"/>
            <Setter Property="BorderBrush" Value="#4D343A48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MusicBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MusicBorder"
                                        Property="Background"
                                        Value="#BF1D222D"/>
                                <Setter TargetName="MusicBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnimationToggleStyle"
               TargetType="CheckBox">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="62" Height="32">
                            <Border x:Name="ToggleTrack"
                                    Background="#4D343A48"
                                    BorderBrush="#6A555D70"
                                    BorderThickness="1"
                                    CornerRadius="16"/>
                            <Ellipse x:Name="ToggleThumb"
                                     Width="24"
                                     Height="24"
                                     Margin="4"
                                     HorizontalAlignment="Left"
                                     Fill="White"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleTrack"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ToggleTrack"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ToggleThumb"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Тонкая полоса прокрутки в цвет выбранной темы -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Margin" Value="6,0,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="9" Background="#11151D">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="7" MinHeight="45">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Width="7"
                                                        Background="{DynamicResource PrimaryBrush}"
                                                        CornerRadius="4"
                                                        Opacity="0.72"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder"
                                                                Property="Opacity"
                                                                Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Margin="28">
        <Grid.RenderTransform>
            <TranslateTransform Y="18"/>
        </Grid.RenderTransform>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <StackPanel>
                <Border Height="190"
                        CornerRadius="20"
                        BorderBrush="#39314F"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Image Source="{DynamicResource LauncherBackgroundImage}"
                               Stretch="UniformToFill"
                               Opacity="0.48"/>
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#B0151822" Offset="0"/>
                            <GradientStop Color="#78181822" Offset="0.62"/>
                            <GradientStop Color="#3821163A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="32" VerticalAlignment="Center">
                            <TextBlock Text="CUSTOM LAUNCHER"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Твой лаунчер — твой стиль"
                                       Margin="0,8,0,0"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Выбери тему — цвет и средневековый фон изменятся сразу."
                                       Margin="0,9,0,0"
                                       Foreground="#CFD2DC"
                                       FontSize="15"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,20,0,0"
                        Padding="24"
                        Background="#A8151922"
                        BorderBrush="#282D39"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Цветовая тема"
                                           Foreground="White"
                                           FontSize="19"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="CurrentThemeText"
                                           Text="Текущая тема: Story Purple"
                                           Margin="0,7,0,0"
                                           Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="13"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="СБРОСИТЬ ТЕМУ"
                                    Width="165"
                                    Height="40"
                                    FontSize="12"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ResetThemeButton_Click"/>
                        </Grid>

                        <WrapPanel x:Name="ThemesPanel" Margin="0,22,0,0">
                            <Button Tag="StoryPurple" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeStoryPurple.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#7057FF"/>
                                            <TextBlock Text="Story Purple" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Tag="Crimson" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeCrimson.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#D94A64"/>
                                            <TextBlock Text="Crimson" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Tag="Emerald" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeEmerald.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#35B982"/>
                                            <TextBlock Text="Emerald" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Tag="IceBlue" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeIceBlue.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#4099E8"/>
                                            <TextBlock Text="Ice Blue" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Tag="Golden" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeGolden.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#D8A13A"/>
                                            <TextBlock Text="Golden" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Tag="DarkAmethyst" Style="{StaticResource ThemeChoiceButtonStyle}" Click="ThemeButton_Click">
                                <Grid>
                                    <Image Source="/StoryLauncher;component/Assets/Images/ThemeDarkAmethyst.png" Stretch="UniformToFill"/>
                                    <Border VerticalAlignment="Bottom" Padding="12,9" Background="#A811141B">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="#A441C5"/>
                                            <TextBlock Text="Dark Amethyst" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                        </WrapPanel>

                        <Border Margin="0,8,0,0"
                                Padding="14"
                                Background="#9611151D"
                                BorderBrush="#292E3A"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Text="Тема меняет фон всего лаунчера, кнопки, выбранный раздел, ползунки и цветовые акценты. Выбор сохраняется автоматически."
                                       Foreground="#9BA1B0"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,28"
                        Padding="24"
                        Background="#A8151922"
                        BorderBrush="#282D39"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Музыка лаунчера"
                                           Foreground="White"
                                           FontSize="19"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="CurrentMusicText"
                                           Text="Сейчас играет: Story Menu"
                                           Margin="0,7,0,0"
                                           Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="13"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="12,7"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SelectedNavigationBrush}"
                                    CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D6;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="{DynamicResource AccentTextBrush}"
                                               FontSize="15"/>
                                    <TextBlock Text="ВЫБЕРИ ТРЕК"
                                               Margin="8,0,0,0"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <WrapPanel x:Name="MusicPanel" Margin="0,20,0,0">
                            <Button Tag="MenuMusic"
                                    Style="{StaticResource MusicChoiceButtonStyle}"
                                    Click="MusicTrackButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44"
                                            Height="44"
                                            Background="{DynamicResource SelectedNavigationBrush}"
                                            CornerRadius="22">
                                        <TextBlock Text="&#xE8D6;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Story Menu" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Основная музыка лаунчера" Margin="0,5,0,0" Foreground="#9097A7" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Tag="GoldenBrown"
                                    Style="{StaticResource MusicChoiceButtonStyle}"
                                    Click="MusicTrackButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44" Height="44" Background="{DynamicResource SelectedNavigationBrush}" CornerRadius="22">
                                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentTextBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Golden Brown × Love Story" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Атмосферная версия" Margin="0,5,0,0" Foreground="#9097A7" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Tag="HideSlowed"
                                    Style="{StaticResource MusicChoiceButtonStyle}"
                                    Click="MusicTrackButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44" Height="44" Background="{DynamicResource SelectedNavigationBrush}" CornerRadius="22">
                                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentTextBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Hide — slowed" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="CS01 Version" Margin="0,5,0,0" Foreground="#9097A7" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Tag="PlayDate"
                                    Style="{StaticResource MusicChoiceButtonStyle}"
                                    Click="MusicTrackButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44" Height="44" Background="{DynamicResource SelectedNavigationBrush}" CornerRadius="22">
                                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentTextBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Play Date" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Melanie" Margin="0,5,0,0" Foreground="#9097A7" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </WrapPanel>

                        <TextBlock Text="Нажми на карточку, чтобы выбрать трек. Выбор сохранится автоматически. Если музыка выключена, трек начнёт играть после её включения."
                                   Margin="0,4,0,0"
                                   Foreground="#8E95A5"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,28"
                        Padding="24"
                        Background="#A8151922"
                        BorderBrush="#282D39"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Анимация аватарки"
                                       Foreground="White"
                                       FontSize="19"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="AnimationStatusText"
                                       Text="Включена — показывается видео в круге"
                                       Margin="0,7,0,0"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="13"/>

                            <TextBlock Text="Если выключить, вместо видео появится обычная картинка. Цветная рамка темы останется."
                                       Margin="0,9,0,0"
                                       Foreground="#8E95A5"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <CheckBox x:Name="AnimationsCheckBox"
                                  Grid.Column="1"
                                  Margin="24,0,4,0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource AnimationToggleStyle}"
                                  Click="AnimationsCheckBox_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
