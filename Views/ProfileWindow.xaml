<Window x:Class="StoryLauncher.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль"
        Icon="/StoryLauncher;component/Assets/Icons/LauncherIcon.ico"
        Width="980"
        Height="700"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource LauncherBackgroundBrush}"
        ShowInTaskbar="False"
        Opacity="0"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="ProfileButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="42"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="Background"
                    Value="#7A242936"/>
            <Setter Property="BorderBrush"
                    Value="#664A5263"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          RenderTransformOrigin="0.5,0.5">

        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="0.96"
                                ScaleY="0.96"/>
                <TranslateTransform Y="18"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <Image Source="{DynamicResource LauncherBackgroundImage}"
               Stretch="UniformToFill"
               Opacity="0.9"/>

        <Border Background="#8E0D0F14"/>

        <Grid Margin="34,28,34,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="ПРОФИЛЬ"
                           Foreground="{DynamicResource AccentTextBrush}"
                           FontSize="12"
                           FontWeight="Bold"/>
                <TextBlock Text="Story Account"
                           Margin="0,4,0,0"
                           Foreground="White"
                           FontSize="27"
                           FontWeight="Bold"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,18,0,14"
                    Padding="26"
                    Background="#9C161922"
                    BorderBrush="#5C3E4556"
                    BorderThickness="1"
                    CornerRadius="22">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,24,0"
                            Background="#5E242936"
                            BorderBrush="#66535B6D"
                            BorderThickness="1"
                            CornerRadius="20"
                            ClipToBounds="True">

                        <Grid>
                            <Border Margin="18"
                                    Background="#3410141D"
                                    CornerRadius="16"/>

                            <TextBlock x:Name="SkinPlaceholderText"
                                       Text="ПОЛНЫЙ СКИН"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#7E8799"
                                       FontSize="16"
                                       FontWeight="Bold"/>

                            <Image x:Name="PlayerSkinImage"
                                   Margin="28,20"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Visibility="Collapsed">
                                <Image.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      BlurRadius="18"
                                                      ShadowDepth="6"
                                                      Opacity="0.8"/>
                                </Image.Effect>
                            </Image>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel Margin="4,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="78"
                                      Height="78"
                                      Margin="0,0,16,0">

                                    <Ellipse Width="72"
                                             Height="72"
                                             Fill="#66242936"/>

                                    <TextBlock x:Name="AvatarPlaceholderText"
                                               Text="?"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#7E8799"
                                               FontSize="25"
                                               FontWeight="Bold"/>

                                    <Image x:Name="PlayerAvatarImage"
                                           Width="72"
                                           Height="72"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="Collapsed">
                                        <Image.Clip>
                                            <EllipseGeometry Center="36,36"
                                                             RadiusX="36"
                                                             RadiusY="36"/>
                                        </Image.Clip>
                                    </Image>

                                    <!-- Рамка находится последней и всегда рисуется поверх аватарки. -->
                                    <Ellipse Width="76"
                                             Height="76"
                                             Stroke="{DynamicResource PrimaryBrush}"
                                             StrokeThickness="3"
                                             Fill="Transparent"
                                             IsHitTestVisible="False"/>
                                </Grid>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="ProfileNameText"
                                               Text="Не авторизован"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               MaxWidth="470"/>

                                    <TextBlock x:Name="ProfileTypeText"
                                               Text="Выберите способ входа"
                                               Margin="0,5,0,0"
                                               Foreground="#B0B7C8"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               MaxWidth="470"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="MicrosoftLoginButton"
                                    Content="ВОЙТИ ЧЕРЕЗ MICROSOFT"
                                    Height="46"
                                    Margin="0,20,0,0"
                                    Foreground="White"
                                    Background="{DynamicResource PrimaryBrush}"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="MicrosoftLoginButton_Click"/>

                            <Grid Margin="0,14,0,12">
                                <Border Height="1"
                                        Background="#4A4D5565"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="ЛОКАЛЬНЫЙ ВХОД"
                                           Padding="12,0"
                                           HorizontalAlignment="Center"
                                           Background="#E1161922"
                                           Foreground="#8F97A8"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="NicknameTextBox"
                                         Grid.Column="0"
                                         Height="42"
                                         Margin="0,0,10,0"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         Foreground="White"
                                         Background="#B8242936"
                                         BorderBrush="#5E4A5263"
                                         BorderThickness="1"
                                         FontSize="13"
                                         Text="StoryPlayer"/>

                                <Button Grid.Column="1"
                                        Content="ИСПОЛЬЗОВАТЬ НИК"
                                        Style="{StaticResource ProfileButtonStyle}"
                                        Background="{DynamicResource SelectedNavigationBrush}"
                                        BorderBrush="{DynamicResource PrimaryBrush}"
                                        Click="OfflineLoginButton_Click"/>
                            </Grid>

                            <TextBlock Text="АВАТАРКА ПРОФИЛЯ"
                                       Margin="0,18,0,8"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="11"
                                       FontWeight="Bold"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Margin="0,0,5,0"
                                        Content="ВЫБРАТЬ СВОЮ"
                                        Style="{StaticResource ProfileButtonStyle}"
                                        Click="ChooseAvatarButton_Click"/>

                                <Button Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Content="ИЗ MINECRAFT-СКИНА"
                                        Style="{StaticResource ProfileButtonStyle}"
                                        Click="RestoreAvatarButton_Click"/>
                            </Grid>

                            <TextBlock Text="СКИН ЛОКАЛЬНОГО ПРОФИЛЯ"
                                       Margin="0,16,0,8"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="11"
                                       FontWeight="Bold"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Margin="0,0,5,0"
                                        Content="ВЫБРАТЬ СКИН 64×64 / 64×32"
                                        Style="{StaticResource ProfileButtonStyle}"
                                        Click="ChooseSkinButton_Click"/>

                                <Button Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Content="СКИН ПО НИКУ"
                                        Style="{StaticResource ProfileButtonStyle}"
                                        Click="RestoreNicknameSkinButton_Click"/>
                            </Grid>

                            <TextBlock Text="Свой файл скина пока меняет предпросмотр профиля. Установку такого скина внутри игры подключим отдельным этапом."
                                       Margin="0,10,0,0"
                                       Foreground="#80889A"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <TextBlock x:Name="ProfileMessageText"
                       Grid.Row="2"
                       Text="Введи существующий Minecraft Java-ник — лаунчер найдёт его голову и полный скин."
                       HorizontalAlignment="Center"
                       Foreground="#8992A4"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>
