<Window x:Class="StoryLauncher.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль"
        Icon="/StoryLauncher;component/Assets/Icons/LauncherIcon.ico"
        Width="780"
        Height="600"
        MinWidth="780"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0F14"
        ShowInTaskbar="False"
        Opacity="0"
        Loaded="Window_Loaded">

    <Grid x:Name="RootGrid"
          RenderTransformOrigin="0.5,0.5">

        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="0.96"
                                ScaleY="0.96"/>

                <TranslateTransform Y="18"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <!-- Фоновый арт -->
        <Image Source="/StoryLauncher;component/Assets/Images/MainBanner.png"
               Stretch="UniformToFill"
               Opacity="0.62"/>

        <!-- Затемнение -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">

                    <GradientStop Color="#7710131A"
                                  Offset="0"/>

                    <GradientStop Color="#F20D0F14"
                                  Offset="0.68"/>

                    <GradientStop Color="#FF0D0F14"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Верхняя часть -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ПРОФИЛЬ"
                               Foreground="#A494FF"
                               FontSize="12"
                               FontWeight="Bold"/>

                    <TextBlock Text="Story Account"
                               Margin="0,5,0,0"
                               Foreground="White"
                               FontSize="25"
                               FontWeight="Bold"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Width="38"
                        Height="38"
                        Content="✕"
                        Foreground="White"
                        Background="#55252A38"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Центральная карточка -->
            <Border Grid.Row="1"
                    Margin="0,22,0,18"
                    Padding="26"
                    Background="#D9161922"
                    BorderBrush="#443E4556"
                    BorderThickness="1"
                    CornerRadius="22">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Полный скин -->
                    <Border Grid.Column="0"
                            Width="160"
                            Height="240"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#252A38"
                            BorderBrush="#4D5363"
                            BorderThickness="1"
                            CornerRadius="18"
                            ClipToBounds="True">

                        <Grid>
                            <TextBlock x:Name="SkinPlaceholderText"
                                       Text="СКИН"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#777D8B"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                            <Image x:Name="PlayerSkinImage"
                                   Margin="10"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Правая часть -->
                    <StackPanel Grid.Column="1"
                                Margin="24,0,0,0"
                                VerticalAlignment="Center">

                        <!-- Голова и ник -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,4">

                            <Border Width="58"
                                    Height="58"
                                    Margin="0,0,14,0"
                                    Background="#252A38"
                                    BorderBrush="#4D5363"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    ClipToBounds="True">

                                <Grid>
                                    <TextBlock x:Name="AvatarPlaceholderText"
                                               Text="?"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#777D8B"
                                               FontSize="22"
                                               FontWeight="Bold"/>

                                    <Image x:Name="PlayerAvatarImage"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock x:Name="ProfileNameText"
                                           Text="Не авторизован"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           MaxWidth="300"/>

                                <TextBlock x:Name="ProfileTypeText"
                                           Text="Выберите способ входа"
                                           Margin="0,5,0,0"
                                           Foreground="#A7ADBC"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           MaxWidth="300"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Content="ВОЙТИ ЧЕРЕЗ MICROSOFT"
                                Height="46"
                                Margin="0,24,0,0"
                                Foreground="White"
                                Background="#725CFF"
                                BorderThickness="0"
                                FontSize="13"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="MicrosoftLoginButton_Click"/>

                        <TextBlock Text="или"
                                   Margin="0,14,0,14"
                                   HorizontalAlignment="Center"
                                   Foreground="#777D8B"
                                   FontSize="12"/>

                        <TextBox x:Name="NicknameTextBox"
                                 Height="40"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 Foreground="White"
                                 Background="#242936"
                                 BorderBrush="#3A4050"
                                 BorderThickness="1"
                                 FontSize="13"
                                 Text="StoryPlayer"/>

                        <Button Content="ИСПОЛЬЗОВАТЬ НИК"
                                Height="44"
                                Margin="0,10,0,0"
                                Foreground="White"
                                Background="#292F3D"
                                BorderBrush="#414859"
                                BorderThickness="1"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="OfflineLoginButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="Для существующего Minecraft Java-ника лаунчер загрузит голову и скин."
                       HorizontalAlignment="Center"
                       Foreground="#717887"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>