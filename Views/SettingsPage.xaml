<Page x:Class="StoryLauncher.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      Title="SettingsPage">

    <Grid Margin="28">
        <Border CornerRadius="20"
                Background="#191D27"
                BorderBrush="#2B3040"
                BorderThickness="1">

            <StackPanel Margin="36">
                <TextBlock Text="Настройки"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"/>

                <TextBlock Text="Оперативная память"
                           Margin="0,30,0,0"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <Slider Minimum="2"
                        Maximum="16"
                        Value="6"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="380"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"/>

                <TextBlock Text="Путь к Java"
                           Margin="0,30,0,0"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBox Width="520"
                         Height="38"
                         HorizontalAlignment="Left"
                         Margin="0,12,0,0"
                         Text="C:\Program Files\Eclipse Adoptium\jdk-21"
                         Padding="10"/>

                <CheckBox Content="Включить музыку в лаунчере"
                          Margin="0,30,0,0"
                          Foreground="White"
                          FontSize="15"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>