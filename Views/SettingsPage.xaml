<Page x:Class="StoryLauncher.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      Title="SettingsPage"
      Opacity="0"
      Loaded="Page_Loaded">

    <Grid x:Name="RootGrid"
          Margin="28"
          RenderTransformOrigin="0.5,0.5">

        <Grid.RenderTransform>
            <TranslateTransform Y="18"/>
        </Grid.RenderTransform>

        <Border CornerRadius="20"
                Background="#191D27"
                BorderBrush="#2B3040"
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="36">

                    <!-- Заголовок -->

                    <TextBlock Text="Настройки"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"/>

                    <!-- ================= RAM ================= -->

                    <Border Margin="0,28,0,0"
                            Padding="22"
                            Background="#131620"
                            BorderBrush="#2B3040"
                            BorderThickness="1"
                            CornerRadius="14">

                        <StackPanel>

                            <DockPanel>

                                <TextBlock Text="Оперативная память"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <Border DockPanel.Dock="Right"
                                        Background="#7C5CFF"
                                        CornerRadius="10"
                                        Padding="12,4">

                                    <TextBlock x:Name="RamValueText"
                                               Text="6 ГБ"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="15"/>

                                </Border>

                            </DockPanel>

                            <TextBlock x:Name="RamMbText"
                                       Margin="0,8,0,0"
                                       Text="Выделено: 6144 МБ"
                                       Foreground="#BFC4D2"
                                       FontSize="14"/>

                            <Slider x:Name="RamSlider"
                                    Margin="0,18,0,0"
                                    Minimum="2"
                                    Maximum="16"
                                    Value="6"
                                    TickFrequency="0.5"
                                    SmallChange="0.5"
                                    LargeChange="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="RamSlider_ValueChanged"/>

                            <Grid Margin="0,8,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="2 ГБ"
                                           Foreground="#8D93A5"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Text="16 ГБ"
                                           Foreground="#8D93A5"
                                           FontSize="12"/>

                            </Grid>

                        </StackPanel>

                    </Border>

                    <!-- ================= JAVA ================= -->

                    <Border Margin="0,22,0,0"
                            Padding="22"
                            Background="#131620"
                            BorderBrush="#2B3040"
                            BorderThickness="1"
                            CornerRadius="14">

                        <StackPanel>

                            <TextBlock Text="Путь к Java"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBox x:Name="JavaPathTextBox"
                                     Margin="0,16,0,0"
                                     Height="40"
                                     Text="C:\Program Files\Eclipse Adoptium\jdk-21"
                                     Padding="10"
                                     Background="#191D27"
                                     Foreground="White"
                                     BorderBrush="#383F55"/>

                        </StackPanel>

                    </Border>

                    <!-- ================= МУЗЫКА ================= -->

                    <Border Margin="0,22,0,0"
                            Padding="22"
                            Background="#131620"
                            BorderBrush="#2B3040"
                            BorderThickness="1"
                            CornerRadius="14">

                        <CheckBox x:Name="MusicCheckBox"
                                  Content="Включить музыку в лаунчере"
                                  FontSize="16"
                                  Foreground="White"
                                  IsChecked="True"
                                  Checked="MusicCheckBox_Checked"
                                  Unchecked="MusicCheckBox_Unchecked"/>

                    </Border>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Page>