<Page x:Class="StoryLauncher.Views.ModpackPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      Title="ModpackPage">

    <Grid Margin="28">
        <Border CornerRadius="20"
                Background="#191D27"
                BorderBrush="#2B3040"
                BorderThickness="1">

            <StackPanel Margin="36">
                <TextBlock Text="Модпак"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"/>

                <TextBlock Text="Story Modpack"
                           Margin="0,12,0,0"
                           Foreground="#8A78FF"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Здесь позже будет информация о версии сборки, модах, размере загрузки и обновлениях."
                           Margin="0,16,0,0"
                           Foreground="#A8ADBA"
                           FontSize="16"
                           TextWrapping="Wrap"/>

                <Button Content="ПРОВЕРИТЬ ФАЙЛЫ"
                        Width="220"
                        Margin="0,30,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>