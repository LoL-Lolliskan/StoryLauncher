<Page x:Class="StoryLauncher.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Opacity="0"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <Style x:Key="CarouselButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#80111620"/>
            <Setter Property="BorderBrush" Value="#506B7280"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#CC6D55FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Тонкая тёмная полоса прокрутки без белых кнопок -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Margin" Value="6,0,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="9" Background="#11151D">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="7" MinHeight="45">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Width="7"
                                                        Background="{DynamicResource PrimaryBrush}"
                                                        CornerRadius="4"
                                                        Opacity="0.72"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder"
                                                                Property="Opacity"
                                                                Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Margin="28">
        <Grid.RenderTransform>
            <TranslateTransform Y="18"/>
        </Grid.RenderTransform>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <StackPanel>
                <Border Height="430"
                        CornerRadius="20"
                        BorderBrush="#2B3040"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid x:Name="SlideContainer">
                        <Image x:Name="NewsImage"
                               Source="/StoryLauncher;component/Assets/Images/MainBanner.png"
                               Stretch="UniformToFill"/>

                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E90B0E15" Offset="0"/>
                                    <GradientStop Color="#8A10131C" Offset="0.55"/>
                                    <GradientStop Color="#3010131C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel Width="650"
                                    Margin="52,0,0,54"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom">
                            <TextBlock x:Name="NewsDateText"
                                       Text="17 ИЮЛЯ 2026"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="NewsTitleText"
                                       Text="Добро пожаловать в StoryLauncher"
                                       Margin="0,10,0,0"
                                       Foreground="White"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="NewsSummaryText"
                                       Text="Здесь будут появляться новости, обновления и интересные события Minecraft."
                                       Margin="0,12,0,0"
                                       Foreground="#D6D9E2"
                                       FontSize="16"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Content="‹"
                                Margin="20,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource CarouselButtonStyle}"
                                Click="PreviousNewsButton_Click"/>
                        <Button Content="›"
                                Margin="0,0,20,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource CarouselButtonStyle}"
                                Click="NextNewsButton_Click"/>

                        <StackPanel x:Name="NewsDotsPanel"
                                    Margin="0,0,0,18"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <Grid Margin="0,22,0,28">
                    <Border
                            Padding="26"
                            Background="#A8151922"
                            BorderBrush="#282D39"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock x:Name="NewsDetailsTitleText"
                                       Text="Подробнее"
                                       Foreground="White"
                                       FontSize="21"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="NewsDetailsText"
                                       Margin="0,16,0,0"
                                       Foreground="#AEB4C2"
                                       FontSize="14"
                                       LineHeight="23"
                                       TextWrapping="Wrap"/>
                            <Button x:Name="OfficialNewsButton"
                                    Content="MINECRAFT OFFICIAL"
                                    Width="270"
                                    Height="44"
                                    Margin="0,22,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OfficialNewsButton_Click"/>
                            <TextBlock Text="StoryLauncher — неофициальный проект. Не одобрен и не связан с Mojang или Microsoft."
                                       Margin="0,16,0,0"
                                       Foreground="#656C7C"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
